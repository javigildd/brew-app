# ──────────────────────────────────────────────────────────────
# Brew — environment variables
# Copy this file to `.env.local` for local dev, and set the same
# variables in Vercel → Project → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────

# ── Auth (simple password gate) ──
# The single password to access the app.
BREW_PASSWORD=change-me
# A long random string used to sign the session cookie.
# Generate one with:  openssl rand -base64 48
BREW_SESSION_SECRET=generate-a-long-random-secret

# ── Supabase (database + photo storage) ──
# From Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# IMPORTANT: the *service role* key (server-only, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (reads the coffee bag photo) ──
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the vision model (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
